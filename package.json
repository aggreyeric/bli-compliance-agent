{
  "name": "bli-compliance-agent",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered legal compliance agent — extracts obligations, scores risk, produces cited compliance reports. Entry for BLI Legal Tech 2 (DoraHacks).",
  "license": "MIT",
  "type": "commonjs",
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "jest --coverage --colors",
    "test:watch": "jest --watch",
    "lint": "echo \"(no linter configured)\" && exit 0"
  },
  "dependencies": {
    "express": "^4.19.2",
    "typescript": "^5.4.5",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.12.12",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "@types/jest": "^29.5.12"
  }
}
